# Copy to .env and adjust as needed: `cp .env.example .env`.
# docker compose reads .env automatically. All values have safe development
# defaults, so an empty or missing .env still runs locally.

# --- Game server: supporting service URLs ---
ML_SERVICE_URL=http://ml_service:8001
BLOCKCHAIN_SERVICE_URL=http://blockchain:8002

# Seconds to wait for the ML and hash-chain HTTP calls.
SERVICE_HTTP_TIMEOUT=5

# --- Game timing ---
# Seconds an unstarted room stays open waiting for a second player.
ROOM_EXPIRY_SECONDS=25
# Seconds a started match may run before timeout scoring applies.
GAME_TIME_LIMIT_SECONDS=600

# --- Matomo / MariaDB credentials ---
# Change these before exposing the stack beyond local development.
MATOMO_DB_ROOT_PASSWORD=rootpassword
MATOMO_DB_NAME=matomo
MATOMO_DB_USER=matomo
MATOMO_DB_PASSWORD=matomo_password
